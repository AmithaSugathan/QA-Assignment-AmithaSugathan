{
	"info": {
		"_postman_id": "4273c144-2e69-40e8-b4df-d6ada8204089",
		"name": "ShipArc Engagement API Tests",
		"description": "Functional, negative, auth, and validation tests for Combined Engagement Score API",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "603be90e-04a0-4bcc-af21-585fe27560b9",
						"exec": [
							"pm.test(\"Login successful\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"let jsonData = pm.response.json();",
							"//Converts the API response body into a JavaScript object. let is used to declare variable",
							"",
							"pm.environment.set(\"authToken\", jsonData.token || jsonData.accessToken);",
							"//Try to read the token from the response body. If it doesn't exist, try to read accessToken. If both don't exist, set authToken to undefined. pm.environment.set is used to set an environment variable.",
							"",
							"pm.test(\"Auth token stored\", function () {",
							"    pm.expect(pm.environment.get(\"authToken\")).to.not.be.undefined;",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "aec53269-4aaa-4d8a-b644-e22543437b06",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"mubarakca@shiparc.ai\",\n  \"password\": \"test@1234\"\n}"
				},
				"url": "{{baseUrl}}/api/auth/login"
			},
			"response": []
		},
		{
			"name": "2. Get Combined Engagement Score (Positive)",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "fdfef849-594b-4a10-8a5d-98eb4f7a9863",
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response time < 2000ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(2000);",
							"});",
							"",
							"//Ensures the API response is formatted as JSON",
							"pm.test(\"Response is JSON\", function () {",
							"    pm.response.to.be.json;",
							"});",
							"",
							"let jsonData = pm.response.json();",
							"",
							"pm.test(\"Response has overallIndex\", function () {",
							"    pm.expect(jsonData).to.have.property(\"overallIndex\");",
							"});",
							"",
							"//overallIndex exists - test passes",
							"pm.test(\"Score is number\", function () {",
							"    pm.expect(jsonData.overallIndex).to.be.a(\"number\");",
							"});",
							"",
							"pm.test(\"Content-Type header\", function () {",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "e640a835-b1d7-40f0-ba60-f6d9d3ee6bb2",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{authToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/admin/dashboard/engagement/combined-engagement-score?companyId=cln8k9sfo8290fip8d59mnv8i&vesselIds=all&startDate=2026-03-01T00:00:01.000Z&endDate=2026-03-22T23:59:59.999Z&dateFilter=CUSTOM",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"dashboard",
						"engagement",
						"combined-engagement-score"
					],
					"query": [
						{
							"key": "companyId",
							"value": "cln8k9sfo8290fip8d59mnv8i"
						},
						{
							"key": "vesselIds",
							"value": "all"
						},
						{
							"key": "startDate",
							"value": "2026-03-01T00:00:01.000Z"
						},
						{
							"key": "endDate",
							"value": "2026-03-22T23:59:59.999Z"
						},
						{
							"key": "dateFilter",
							"value": "CUSTOM"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Missing companyId (Negative)",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "f37c8453-a5fe-411b-b7ff-0262b9b574e4",
						"exec": [
							"//Passes if the value of pm.response.code is either 400:Bad Request or 422: Unprocessable Entity(logically impossible data)",
							"//The request is sent without companyId, the API cannot process it properly.Expected response: HTTP 400 (Bad Request) or 422 (Unprocessable Entity)",
							"pm.test(\"Should fail (400/422)\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "1c85d356-fad9-4055-834b-7d22ad9e6b75",
